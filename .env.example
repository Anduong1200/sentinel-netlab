# =============================================================================
# SENTINEL NETLAB - UNIFIED CONFIGURATION TEMPLATE
# =============================================================================
# Usage:
#   1. Copy to .env (Production) or .env.lab (Lab)
#   2. Fill in REQUIRED values (Generate using: openssl rand -hex 32)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CORE SECRETS (REQUIRED IN PRODUCTION)
# -----------------------------------------------------------------------------
CONTROLLER_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
CONTROLLER_HMAC_SECRET=CHANGE_ME_openssl_rand_hex_16

# Database
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=sentinel

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# Object Storage (MinIO)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
S3_BUCKET=sentinel-artifacts

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# -----------------------------------------------------------------------------
# 2. SECURITY & NETWORK
# -----------------------------------------------------------------------------
# Enforce HTTPS (False for local dev, True for Prod behind Nginx)
REQUIRE_TLS=true
# Trust these proxies (MUST match your actual proxy IPs in production)
# Default: compose sentinel-net only. Set to your LB/nginx IP for prod.
TRUSTED_PROXIES=127.0.0.1,172.28.0.0/16
# CORS allowed origins (comma-separated for multiple)
# Default: dashboard URL. Set to your actual dashboard URL in prod.
CORS_ORIGINS=http://localhost:8050
# Enforce HMAC Request Signing
REQUIRE_HMAC=true
# Rate Limits
RATE_LIMIT_DEFAULT=100 per minute
RATE_LIMIT_SENSOR=200 per minute

# -----------------------------------------------------------------------------
# 3. LAB & SIMULATION SETTINGS (Only for .env.lab)
# -----------------------------------------------------------------------------
# Enable Lab Mode (Attack Simulation)
SENTINEL_LAB_MODE=false
# API Key for Lab Control (if Lab Mode is enabled)
LAB_API_KEY=CHANGE_ME_if_lab_mode_enabled
# Wireless Interface for Injection (Host Network Mode)
WIFI_INTERFACE=wlan0

# -----------------------------------------------------------------------------
# 4. OBSERVABILITY
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
# Prometheus Retention (Days)
METRICS_RETENTION_DAYS=15


# -----------------------------------------------------------------------------
# 5. DISTRIBUTED GEO-LOCATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Enable distributed geo enrichment in controller /api/v1/networks
GEO_ENABLED=false
# Sensor static positions in local ENU meters (x=east, y=north, z optional)
SENSOR_POSITIONS_JSON='{"sensor-01":{"x":0,"y":0},"sensor-02":{"x":20,"y":0},"sensor-03":{"x":10,"y":17.3}}'
# Local origin used to project x/y to lat/lon
GEO_ORIGIN_LAT=10.776889
GEO_ORIGIN_LON=106.700806
# Window of telemetry used per BSSID for estimation
GEO_SAMPLE_WINDOW_SEC=30

# Sensor-side geo hook (per sensor process)
SENSOR_GEO_ENABLED=false
SENSOR_GEO_X_M=0
SENSOR_GEO_Y_M=0
SENSOR_GEO_Z_M=0
SENSOR_GEO_HEATMAP_ENABLED=false
SENSOR_GEO_HEATMAP_WIDTH_M=50
SENSOR_GEO_HEATMAP_HEIGHT_M=50
SENSOR_GEO_HEATMAP_RESOLUTION_M=1
SENSOR_GEO_HEATMAP_EXPORT_PATH=/var/lib/wifi-scanner/geo_heatmap.json
SENSOR_GEO_HEATMAP_EXPORT_INTERVAL_SEC=60


